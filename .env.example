# Root .env for `docker compose up` — copy to .env and fill in real values.
# Never commit the real .env file (it's already in .gitignore).
#
# Generate strong secrets with: openssl rand -hex 32

DB_PASSWORD=replace-with-a-strong-database-password
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# The single public origin your users will visit (through the `edge` nginx
# service). Must match exactly, including scheme — used for CORS + CSP.
CORS_ORIGIN=https://your-domain.example
